{
     "version": 8,
     "name": "toronto-ortho",
     "metadata": {
          "maputnik:renderer": "mbgljs"
     },
     "glyphs": "https://geographyclub.github.io/toronto-map/assets/fonts/{fontstack}/{range}.pbf",
     "sprite": "https://geographyclub.github.io/toronto-map/assets/sprites/sprites-maki",
     "sources": {
          "osm": {
               "type": "vector",
               "url": "https://vector.openstreetmap.org/shortbread_v1/tilejson.json"
          },
          "toronto_wards": {
               "type": "vector",
               "tiles": ["https://geographyclub.github.io/toronto-map/data/toronto_wards/{z}/{x}/{y}.pbf"]
          },
          "toronto_ward_centroids": {
               "type": "vector",
               "tiles": ["https://geographyclub.github.io/toronto-map/data/toronto_ward_centroids/{z}/{x}/{y}.pbf"]
          },
          "toronto_neighborhoods": {
               "type": "vector",
               "tiles": ["https://geographyclub.github.io/toronto-map/data/toronto_neighborhoods/{z}/{x}/{y}.pbf"]
          },
          "toronto_neighborhood_centroids": {
               "type": "vector",
               "tiles": ["https://geographyclub.github.io/toronto-map/data/toronto_neighborhood_centroids/{z}/{x}/{y}.pbf"]
          },
          "toronto_bia": {
               "type": "vector",
               "tiles": ["https://geographyclub.github.io/toronto-map/data/toronto_bia/{z}/{x}/{y}.pbf"]
          },
          "toronto_bia_centroids": {
               "type": "vector",
               "tiles": ["https://geographyclub.github.io/toronto-map/data/toronto_bia_centroids/{z}/{x}/{y}.pbf"]
          },
          "toronto_buildings": {
               "type": "vector",
               "tiles": ["https://torontotechweek.github.io/data/toronto_buildings/{z}/{x}/{y}.pbf"]
          },
          "toronto_centreline": {
               "type": "vector",
               "tiles": ["https://geographyclub.github.io/toronto-map/data/toronto_centreline/{z}/{x}/{y}.pbf"]
          },
          "toronto_intersections": {
               "type": "vector",
               "tiles": ["https://geographyclub.github.io/toronto-map/data/toronto_intersections/{z}/{x}/{y}.pbf"]
          },
          "toronto_centreline_low": {
               "type": "vector",
               "tiles": ["https://geographyclub.github.io/toronto-map/data/toronto_centreline_low/{z}/{x}/{y}.pbf"]
          },
          "toronto_property_boundaries": {
               "type": "vector",
               "tiles": ["https://geographyclub.github.io/toronto-map/data/toronto_property_boundaries/{z}/{x}/{y}.pbf"]
          },
          "toronto_property_boundary_lines": {
               "type": "vector",
               "tiles": ["https://geographyclub.github.io/toronto-map/data/toronto_property_boundary_lines/{z}/{x}/{y}.pbf"]
          },
          "toronto_roadway": {
               "type": "vector",
               "tiles": ["https://mapcity.io/toronto-bia/data/toronto_roadway/{z}/{x}/{y}.pbf"]
          },
          "toronto_address_points": {
               "type": "vector",
               "tiles": ["https://geographyclub.github.io/toronto-map/data/toronto_address_points/{z}/{x}/{y}.pbf"]
          },
          "toronto_ortho": {
               "type": "raster",
               "tiles": ["https://gis.toronto.ca/arcgis/rest/services/basemap/cot_ortho/MapServer/tile/{z}/{y}/{x}"],
               "tileSize": 256
          },
		"toronto_green_spaces": {
			"type": "vector",
			"tiles": ["https://geographyclub.github.io/toronto-map/data/toronto_green_spaces/{z}/{x}/{y}.pbf"]
		},
		"toronto_green_spaces_hatch": {
			"type": "vector",
			"tiles": ["https://geographyclub.github.io/toronto-map/data/toronto_green_spaces_hatch/{z}/{x}/{y}.pbf"]
		}           
     },
     "layers": [
          {
               "id": "toronto_ortho",
               "type": "raster",
               "source": "toronto_ortho",
               "paint": {
                    "raster-saturation": -0.8,
                    "raster-contrast": 0,
                    "raster-brightness-min": 1,
                    "raster-brightness-max": 0,
                    "raster-hue-rotate": 0
               }
          },
          {
               "id": "buildings",
               "source": "toronto_buildings",
               "source-layer": "toronto_buildings",
               "type": "fill-extrusion",
               "paint": {
                    "fill-extrusion-color": "#018B76",
                    "fill-extrusion-height": ["case", ["!=", ["get", "max_height"], null], ["*", ["get", "max_height"], 0.5], ["!=", ["get", "avg_height"], null], ["*", ["get", "avg_height"], 0.5], 5],
                    "fill-extrusion-base": 0,
                    "fill-extrusion-opacity": ["interpolate", ["linear"], ["zoom"], 15, 0, 16, 0.4, 17, 0.4, 18, 0]
               }
          },
          {
               "source": "osm",
               "id": "highway-name-minor",
               "type": "symbol",
               "source-layer": "street_labels",
               "filter": ["in", "kind", "unclassified", "residential", "living_street"],
               "layout": {
                    "text-field": "{name}",
                    "text-transform": "uppercase",
                    "text-rotation-alignment": "map",
                    "text-font": ["notosans"],
                    "text-letter-spacing": 0.2,
                    "text-allow-overlap": false,
                    "text-ignore-placement": false,
                    "symbol-placement": "line",
                    "text-anchor": "center",
                    "text-size": ["interpolate", ["exponential", 1.5], ["zoom"], 10, 4, 20, 25],
                    "symbol-sort-key": 10
               },
               "paint": {
                    "text-color": "hsl(50, 10%, 93%)",
                    "text-opacity": ["interpolate", ["linear"], ["zoom"], 14, 0, 15, 1]
               }
          },
          {
               "source": "osm",
               "id": "highway-name-major",
               "type": "symbol",
               "source-layer": "street_labels",
               "filter": ["in", "kind", "motorway", "trunk", "primary", "secondary", "tertiary"],
               "layout": {
                    "text-field": "{name}",
                    "text-transform": "uppercase",
                    "text-rotation-alignment": "map",
                    "text-font": ["notosans"],
                    "text-letter-spacing": 0.2,
                    "text-allow-overlap": false,
                    "text-ignore-placement": false,
                    "symbol-placement": "line",
                    "text-anchor": "center",
                    "text-size": ["interpolate", ["exponential", 1.5], ["zoom"], 10, 4, 20, 30],
                    "symbol-sort-key": 100
               },
               "paint": {
                    "text-color": "hsl(50, 10%, 93%)",
                    "text-opacity": ["interpolate", ["linear"], ["zoom"], 10, 0, 11, 1]
               }
          }
     ]
}
