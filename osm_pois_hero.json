{
	"version": 8,
	"name": "toronto-ortho",
	"metadata": {
		"maputnik:renderer": "mbgljs"
	},
	"glyphs": "https://geographyclub.github.io/toronto-map/assets/fonts/{fontstack}/{range}.pbf",
	"sprite": "https://geographyclub.github.io/toronto-map/assets/sprites/sprites-hero",
	"sources": {
		"osm": {
			"type": "vector",
			"url": "https://vector.openstreetmap.org/shortbread_v1/tilejson.json"
		},
		"toronto_ortho": {
			"type": "raster",
			"tiles": [
				"https://gis.toronto.ca/arcgis/rest/services/basemap/cot_ortho/MapServer/tile/{z}/{y}/{x}"
			],
			"tileSize": 256
		}
	},
	"layers": [
		{
			"id": "toronto_ortho",
			"type": "raster",
			"source": "toronto_ortho",
			"paint": {
				"raster-saturation": 0.2,
				"raster-contrast": -0.2,
				"raster-brightness-min": 0,
				"raster-brightness-max": 0.8
			}
		},
		{
			"id": "poi-amenity",
			"type": "symbol",
			"source": "osm",
			"source-layer": "pois",
			"filter": ["all", ["to-boolean", ["get", "amenity"]], ["!=", ["get", "name"], null]],
			"layout": {
				"symbol-placement": "point",
				"icon-image":["match",["get","amenity"],"arts_centre","academic-cap","atm","banknotes","bank","building-office","bar","sparkles","bench","rectangle-stack","bicycle_rental","arrow-path","biergarten","sparkles","cafe","beaker","car_rental","truck","car_sharing","truck","car_wash","truck","cinema","film","college","academic-cap","community_centre","building-library","dentist","face-smile","doctors","heart","dog_park","user-group","drinking_water","beaker","embassy","building-office","fast_food","bolt","fire_station","fire","fountain","cloud","grave_yard","x-circle","hospital","heart","hunting_stand","arrow-path","library","book-open","marketplace","shopping-cart","nightclub","sparkles","nursing_home","user-group","pharmacy","plus-circle","place_of_worship","building-library","playground","face-smile","police","shield-check","post_box","inbox","post_office","inbox-stack","prison","lock-closed","pub","sparkles","recycling","arrows-right-left","restaurant","sparkles","school","academic-cap","shelter","home","telephone","phone","theatre","film","toilets","circle-stack","townhall","building-office","vending_machine","cube","veterinary","heart","waste_basket","trash","map-pin"],

				"icon-size": 1,
				"icon-anchor": "bottom",
				"icon-optional": true,

				"text-field": ["get", "name"],
				"text-font": ["notosans"],
				"text-size": 14,
				"text-max-width": 10,
				"text-line-height": 1.1,

				"text-anchor": "top",
				"text-offset": [0, 0.2],

				"icon-allow-overlap": false,
				"text-allow-overlap": false,
				"icon-ignore-placement": false,
				"text-ignore-placement": false
			},

			"paint": {
				"icon-opacity": ["interpolate", ["linear"], ["zoom"], 15, 0, 16, 1],
				"text-opacity": ["interpolate", ["linear"], ["zoom"], 15, 0, 16, 1],

				"icon-color": "#fff",
				"text-color": "#fff",

				"icon-halo-color": "hsla( 0, 0%, 0%, 0.2)",
				"icon-halo-width": 1,
				"icon-halo-blur": 1,
				"text-halo-color": "hsla( 0, 0%, 0%, 0.2)",
				"text-halo-width": 1,
				"text-halo-blur": 1
			}
		}
	]
}