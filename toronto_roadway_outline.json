{
	"version": 8,
	"name": "osm",
	"metadata": {
		"maputnik:renderer": "mbgljs"
	},
	"glyphs": "https://geographyclub.github.io/toronto-map/assets/fonts/{fontstack}/{range}.pbf",
	"sprite": "https://geographyclub.github.io/toronto-map/assets/sprites/sprites-maki",
	"sources": {
		"toronto_wards": {
			"type": "vector",
			"tiles": ["https://geographyclub.github.io/toronto-map/data/toronto_wards/{z}/{x}/{y}.pbf"]
		},
		"toronto_ward_centroids": {
			"type": "vector",
			"tiles": ["https://geographyclub.github.io/toronto-map/data/toronto_ward_centroids/{z}/{x}/{y}.pbf"]
		},		
		"toronto_neighborhoods": {
			"type": "vector",
			"tiles": ["https://geographyclub.github.io/toronto-map/data/toronto_neighborhoods/{z}/{x}/{y}.pbf"]
		},		
		"toronto_neighborhood_centroids": {
			"type": "vector",
			"tiles": ["https://geographyclub.github.io/toronto-map/data/toronto_neighborhood_centroids/{z}/{x}/{y}.pbf"]
		},
		"toronto_bia": {
			"type": "vector",
			"tiles": ["https://geographyclub.github.io/toronto-map/data/toronto_bia/{z}/{x}/{y}.pbf"]
		},
		"toronto_bia_centroids": {
			"type": "vector",
			"tiles": ["https://geographyclub.github.io/toronto-map/data/toronto_bia_centroids/{z}/{x}/{y}.pbf"]
		},		
		"toronto_buildings": {
			"type": "vector",
			"tiles": ["https://torontotechweek.github.io/data/toronto_buildings/{z}/{x}/{y}.pbf"]
		},
		"toronto_centreline": {
			"type": "vector",
			"tiles": ["https://geographyclub.github.io/toronto-map/data/toronto_centreline/{z}/{x}/{y}.pbf"]
		},
		"toronto_property_boundary_lines": {
			"type": "vector",
			"tiles": ["https://geographyclub.github.io/toronto-map/data/toronto_property_boundary_lines/{z}/{x}/{y}.pbf"]
		},
		"toronto_roadway": {
			"type": "vector",
			"tiles": ["https://mapcity.io/toronto-bia/data/toronto_roadway/{z}/{x}/{y}.pbf"]
		},
		"toronto_sidewalks": {
			"type": "vector",
			"tiles": ["https://geographyclub.github.io/toronto-map/data/toronto_sidewalks/{z}/{x}/{y}.pbf"]
		},
		"toronto_green_spaces": {
			"type": "vector",
			"tiles": ["https://geographyclub.github.io/toronto-map/data/toronto_green_spaces/{z}/{x}/{y}.pbf"]
		},
		"toronto_green_spaces_hatch": {
			"type": "vector",
			"tiles": ["https://geographyclub.github.io/toronto-map/data/toronto_green_spaces_hatch/{z}/{x}/{y}.pbf"]
		},						
		"toronto_address_points": {
			"type": "vector",
			"tiles": ["https://geographyclub.github.io/toronto-map/data/toronto_address_points/{z}/{x}/{y}.pbf"]
		}		
	},
	"layers": [
		{
			"id": "background",
			"type": "background",
			"paint": {
				"background-color": "hsl(50, 10%, 93%)"
			}
		},
		{
			"id": "property_boundary_line",
			"source": "toronto_property_boundary_lines",
			"source-layer": "toronto_property_boundary_lines",
			"type": "line",
			"paint": {
				"line-color": "hsl(0, 0%, 50%)",
				"line-width": 2,
				"line-dasharray": [2, 2],
				"line-opacity": ["interpolate", ["linear"], ["zoom"], 15, 0, 16, 0.4]
			}
		},
		{
			"id": "green-spaces-outline",
			"source": "toronto_green_spaces",
			"source-layer": "toronto_green_spaces",
            "type": "line",
			"paint": {
			  "line-color": "hsl(0, 0%, 50%)",
			  "line-width": 6,
			  "line-opacity": ["interpolate", ["linear"], ["zoom"], 15, 0, 16, 0.4]
			}
		},		
		{
			"id": "green-spaces",
			"source": "toronto_green_spaces",
			"source-layer": "toronto_green_spaces",
            "type": "fill",
			"paint": {
			  "fill-color": "hsl(50, 10%, 93%)",
			  "fill-opacity": 1
			}
		},		
		{
			"id": "green-spaces-hatch",
			"source": "toronto_green_spaces_hatch",
			"source-layer": "toronto_green_spaces_hatch",
            "type": "line",
			"paint": {
			  "line-color": "hsl(0, 0%, 50%)",
			  "line-width": 1,
			  "line-opacity": ["interpolate", ["linear"], ["zoom"], 15, 0, 16, 0.4]
			}
		},				
		{
			"id": "roadway-outline",
			"source": "toronto_roadway",
			"source-layer": "toronto_roadway",
            "type": "line",
			"paint": {
			  "line-color": "hsl(0, 0%, 50%)",
			  "line-width": 6,
			  "line-opacity": ["interpolate", ["linear"], ["zoom"], 15, 0, 16, 0.4]
			}
		},
		{
			"id": "roadway",
			"source": "toronto_roadway",
			"source-layer": "toronto_roadway",
            "type": "fill",
			"paint": {
			  "fill-color": "hsl(50, 10%, 93%)",
			  "fill-opacity": 1
			}
		},
		{
			"id": "sidewalk",
			"source": "toronto_sidewalks",
			"source-layer": "toronto_sidewalks",
            "type": "fill",
			"paint": {
			  "fill-color": "hsl(50, 10%, 70%)",
			  "fill-opacity": 0.1
			}
		},						
		{
			"id": "address-points",
			"source": "toronto_address_points",
			"source-layer": "toronto_address_points",
			"type": "symbol",
			"layout": {
				"text-field": "{address_number}",
				"text-transform": "uppercase",
				"text-rotation-alignment": "map",
				"text-font": [ "montserrat-regular" ],
				"text-letter-spacing": 0.2,
				"symbol-placement": "point",
				"symbol-sort-key": 1,
				"text-anchor": "center",
				"text-rotate": -16,
				"text-size": [ "interpolate", [ "exponential", 1.5 ], [ "zoom" ], 15, 0, 18, 12 ]
			},
			"paint": {
				"text-color": "hsl(0, 0%, 60%)",
				"text-opacity": [ "interpolate", [ "linear" ], [ "zoom" ], 15, 0, 16, 1 ],
				"text-halo-color": "hsl(50, 10%, 93%)",
				"text-halo-width": 5
			}
		},
		{
			"id": "address-labels",
			"source": "toronto_address_points",
			"source-layer": "toronto_address_points",
			"filter": [
				"all",
				["has", "place_name"],
				["!=", ["get", "place_name"], "None"]
			],			
			"type": "symbol",
			"layout": {
				"text-field": ["get", "place_name"],
				"text-rotation-alignment": "map",
				"text-font": [ "montserrat-regular" ],
				"symbol-placement": "point",
				"symbol-sort-key": 10,
				"text-anchor": "center",
				"text-rotate": -16,
				"text-size": [ "interpolate", [ "exponential", 1.5 ], [ "zoom" ], 15, 0, 18, 12 ]
			},
			"paint": {
				"text-color": "hsl(0, 0%, 60%)",
				"text-opacity": [ "interpolate", [ "linear" ], [ "zoom" ], 15, 0, 16, 1 ],
				"text-halo-color": "hsl(50, 10%, 93%)",
				"text-halo-width": 5
			}
		},				
		{
			"id": "centreline-label-minor",
			"source": "toronto_centreline",
			"source-layer": "toronto_centreline",
			"filter": [
				"all",
				["has", "LINEAR_NAME_FULL"],
				[
					"in",
					"FEATURE_CODE_DESC",
					"Local", "Laneway", "Trail"
				]
			],
			"type": "symbol",
			"layout": {
				"text-field": "{LINEAR_NAME_FULL}",
				"text-transform": "uppercase",
				"text-rotation-alignment": "map",
				"text-font": [ "montserrat-regular" ],
				"text-letter-spacing": 0.2,
				"symbol-placement": "line",
				"symbol-sort-key": 100,
				"symbol-spacing": [ "interpolate", [ "linear" ], [ "zoom" ], 15, 250, 20, 300 ],
				"text-anchor": "center",
				"text-size": [ "interpolate", [ "exponential", 1.5 ], [ "zoom" ], 15, 4, 20, 30 ]
			},
			"paint": {
				"text-color": "hsl(0, 0%, 60%)",
				"text-opacity": [ "interpolate", [ "linear" ], [ "zoom" ], 15, 0, 16, 1 ],
				"text-halo-color": "hsl(50, 10%, 93%)",
				"text-halo-width": 5
			}
		},
		{
			"id": "centreline-label-major",
			"source": "toronto_centreline",
			"source-layer": "toronto_centreline",
			"filter": [
				"all",
				["has", "LINEAR_NAME_FULL"],
				[
					"in",
					"FEATURE_CODE_DESC",
					"Collector", "Expressway", "Major Arterial", "Minor Arterial"
				]
			],
			"type": "symbol",
			"layout": {
				"text-field": "{LINEAR_NAME_FULL}",
				"text-transform": "uppercase",
				"text-rotation-alignment": "map",
				"text-font": [ "montserrat-regular" ],
				"text-letter-spacing": 0.2,
				"symbol-placement": "line",
				"symbol-sort-key": 100,
				"symbol-spacing": [ "interpolate", [ "linear" ], [ "zoom" ], 15, 250, 20, 300 ],
				"text-anchor": "center",
				"text-size": [ "interpolate", [ "exponential", 1.5 ], [ "zoom" ], 15, 6, 20, 60 ]
			},
			"paint": {
				"text-color": "hsl(0, 0%, 60%)",
				"text-opacity": [ "interpolate", [ "linear" ], [ "zoom" ], 15, 0, 16, 1 ],
				"text-halo-color": "hsl(50, 10%, 93%)",
				"text-halo-width": 5
			}
		},
		{
			"id": "neighborhood-labels",
			"type": "symbol",
			"source": "toronto_neighborhood_centroids",
			"source-layer": "toronto_neighborhood_centroids",
			"layout": {
				"text-field": ["get", "area_name"],
				"text-size": [
					"interpolate",
					["linear"],
					["zoom"],
					12, 6,
					16, 40
				],
				"text-font": ["montserrat-semibold"],
				"text-transform": "uppercase",
				"text-max-width": 5,
				"text-line-height": 1.2,
				"text-allow-overlap": true,
				"text-ignore-placement": false,
				"text-rotation-alignment": "map",
				"text-pitch-alignment": "map",
				"text-rotate": -16
			},
			"paint": {
				"text-color": "hsl(202, 90%, 0%)",
				"text-opacity": ["interpolate", ["linear"], ["zoom"], 12, 0, 13, 0.2, 17, 0.2, 18, 0],
				"text-halo-width": 0,
				"text-halo-color": "hsl(50, 10%, 93%)"
			}
		}		
	]
}
