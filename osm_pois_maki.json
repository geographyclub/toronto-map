{
	"version": 8,
	"name": "toronto-ortho",
	"metadata": {
		"maputnik:renderer": "mbgljs"
	},
	"glyphs": "https://geographyclub.github.io/toronto-map/assets/fonts/{fontstack}/{range}.pbf",
	"sprite": "https://geographyclub.github.io/toronto-map/assets/sprites/sprites-maki",
	"sources": {
		"osm": {
			"type": "vector",
			"url": "https://vector.openstreetmap.org/shortbread_v1/tilejson.json"
		},
		"toronto_ortho": {
			"type": "raster",
			"tiles": [
				"https://gis.toronto.ca/arcgis/rest/services/basemap/cot_ortho/MapServer/tile/{z}/{y}/{x}"
			],
			"tileSize": 256
		}
	},
	"layers": [
		{
			"id": "toronto_ortho",
			"type": "raster",
			"source": "toronto_ortho",
			"paint": {
				"raster-saturation": 0.2,
				"raster-contrast": -0.2,
				"raster-brightness-min": 0,
				"raster-brightness-max": 0.8
			}
		},
		{
			"id": "poi-amenity",
			"type": "symbol",
			"source": "osm",
			"source-layer": "pois",
			"filter": ["all", ["to-boolean", ["get", "amenity"]], ["!=", ["get", "name"], null]],
			"layout": {
				"symbol-placement": "point",
				"icon-image": ["match", ["get", "amenity"], "arts_centre", "art-gallery", "atm", "bank", "bank", "bank", "bar", "bar", "bench", "marker", "bicycle_rental", "bicycle-share", "biergarten", "beer", "cafe", "cafe", "car_rental", "car-rental", "car_sharing", "car-rental", "car_wash", "car-repair", "cinema", "cinema", "college", "college", "community_centre", "town", "dentist", "dentist", "doctors", "doctor", "dog_park", "dog-park", "drinking_water", "drinking-water", "embassy", "embassy", "fast_food", "fast-food", "fire_station", "fire-station", "fountain", "water", "grave_yard", "cemetery", "hospital", "hospital", "hunting_stand", "viewpoint", "library", "library", "marketplace", "shop", "nightclub", "music", "nursing_home", "lodging", "pharmacy", "pharmacy", "place_of_worship", "place-of-worship", "playground", "playground", "police", "police", "post_box", "post", "post_office", "post", "prison", "prison", "pub", "beer", "recycling", "recycling", "restaurant", "restaurant", "school", "school", "shelter", "shelter", "telephone", "telephone", "theatre", "theatre", "toilets", "toilet", "townhall", "town-hall", "vending_machine", "shop", "veterinary", "veterinary", "waste_basket", "waste-basket", "information"],

				"icon-size": 1,
				"icon-anchor": "bottom",
				"icon-optional": true,

				"text-field": ["get", "name"],
				"text-font": ["notosans"],
				"text-size": 10,
				"text-max-width": 10,
				"text-line-height": 1.1,

				"text-anchor": "top",
				"text-offset": [0, 0.2],

				"icon-allow-overlap": false,
				"text-allow-overlap": false,
				"icon-ignore-placement": false,
				"text-ignore-placement": false
			},

			"paint": {
				"icon-opacity": ["interpolate", ["linear"], ["zoom"], 15, 0, 16, 1],
				"text-opacity": ["interpolate", ["linear"], ["zoom"], 15, 0, 16, 1],

				"icon-color": "#fff",
				"text-color": "#fff",

				"text-halo-color": "rgba(0,0,0,0.7)",
				"text-halo-width": 0,
				"text-halo-blur": 0
			}
		}
	]
}