{
	"version": 8,
	"name": "toronto-ortho",
	"metadata": {
		"maputnik:renderer": "mbgljs"
	},
	"glyphs": "https://geographyclub.github.io/toronto-map/assets/fonts/{fontstack}/{range}.pbf",
	"sprite": "https://geographyclub.github.io/toronto-map/assets/sprites/sprites",
	"sources": {
		"osm": {
			"type": "vector",
			"url": "https://vector.openstreetmap.org/shortbread_v1/tilejson.json"
		},
		"toronto_ortho": {
			"type": "raster",
			"tiles": [
				"https://gis.toronto.ca/arcgis/rest/services/basemap/cot_ortho/MapServer/tile/{z}/{y}/{x}"
			],
			"tileSize": 256
		}
	},
	"layers": [
		{
			"id": "toronto_ortho",
			"type": "raster",
			"source": "toronto_ortho",
			"paint": {
				"raster-saturation": 0.2,
				"raster-contrast": -0.2,
				"raster-brightness-min": 0,
				"raster-brightness-max": 0.8
			}
		},
		{
			"id": "poi-amenity",
			"type": "symbol",
			"source": "osm",
			"source-layer": "pois",
			"filter": ["all", ["to-boolean", ["get", "amenity"]], ["!=", ["get", "name"], null]],
			"layout": {
				"symbol-placement": "point",
				"icon-image": ["match", ["get", "amenity"], "arts_centre", "icon-art_gallery", "atm", "icon-atm", "bank", "icon-bank", "bar", "icon-bar", "bench", "icon-bench", "bicycle_rental", "icon-bicycle_share", "biergarten", "icon-beergarden", "cafe", "icon-cafe", "car_rental", "icon-car_rental", "car_sharing", "icon-car_rental", "car_wash", "icon-car_wash", "cinema", "icon-cinema", "college", "icon-college", "community_centre", "icon-community", "dentist", "icon-dentist", "doctors", "icon-doctor", "dog_park", "icon-dog_park", "drinking_water", "icon-drinking_water", "embassy", "icon-embassy", "fast_food", "icon-fast_food", "fire_station", "icon-fire_station", "fountain", "icon-fountain", "grave_yard", "icon-cemetery", "hospital", "icon-hospital", "hunting_stand", "icon-huntingstand", "library", "icon-library", "marketplace", "icon-marketplace", "nightclub", "icon-nightclub", "nursing_home", "icon-nursinghome", "pharmacy", "icon-pharmacy", "place_of_worship", "icon-place_of_worship", "playground", "icon-playground", "police", "icon-police", "post_box", "icon-postbox", "post_office", "icon-post", "prison", "icon-prison", "pub", "icon-beer", "recycling", "icon-recycling", "restaurant", "icon-restaurant", "school", "icon-school", "shelter", "icon-shelter", "telephone", "icon-telephone", "theatre", "icon-theatre", "toilets", "icon-toilet", "townhall", "icon-town_hall", "vending_machine", "icon-vendingmachine", "veterinary", "icon-veterinary", "waste_basket", "icon-waste_basket", "transport-information"],

				"icon-size": 0.6,
				"icon-anchor": "bottom",
				"icon-optional": true,

				"text-field": ["get", "name"],
				"text-font": ["notosans"],
				"text-size": 10,
				"text-max-width": 10,
				"text-line-height": 1.1,

				"text-anchor": "top",
				"text-offset": [0, 0.2],

				"icon-allow-overlap": false,
				"text-allow-overlap": false,
				"icon-ignore-placement": false,
				"text-ignore-placement": false
			},

			"paint": {
				"icon-opacity": ["interpolate", ["linear"], ["zoom"], 15, 0, 16, 1],
				"text-opacity": ["interpolate", ["linear"], ["zoom"], 15, 0, 16, 1],

				"icon-color": "#fff",
				"text-color": "#fff",

				"text-halo-color": "rgba(0,0,0,0.7)",
				"text-halo-width": 0,
				"text-halo-blur": 0
			}
		}
	]
}