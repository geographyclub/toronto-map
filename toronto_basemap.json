{
	"version": 8,
	"name": "osm",
	"metadata": {
		"maputnik:renderer": "mbgljs"
	},
	"glyphs": "https://geographyclub.github.io/toronto-map/assets/fonts/{fontstack}/{range}.pbf",
	"sprite": "https://geographyclub.github.io/toronto-map/assets/sprites/sprites",
	"sources": {
		"osm": {
			"type": "vector",
			"url": "https://vector.openstreetmap.org/shortbread_v1/tilejson.json"
		},		
		"toronto_ortho": {
			"type": "raster",
			"tiles": ["https://gis.toronto.ca/arcgis/rest/services/basemap/cot_ortho/MapServer/tile/{z}/{y}/{x}"],
			"tileSize": 256
		},		
		"toronto_wards": {
			"type": "vector",
			"tiles": ["https://geographyclub.github.io/toronto-map/data/toronto_wards/{z}/{x}/{y}.pbf"]
		},
		"toronto_ward_centroids": {
			"type": "vector",
			"tiles": ["https://geographyclub.github.io/toronto-map/data/toronto_ward_centroids/{z}/{x}/{y}.pbf"]
		},		
		"toronto_neighborhoods": {
			"type": "vector",
			"tiles": ["https://geographyclub.github.io/toronto-map/data/toronto_neighborhoods/{z}/{x}/{y}.pbf"]
		},		
		"toronto_neighborhood_centroids": {
			"type": "vector",
			"tiles": ["https://geographyclub.github.io/toronto-map/data/toronto_neighborhood_centroids/{z}/{x}/{y}.pbf"]
		},
		"toronto_bia": {
			"type": "vector",
			"tiles": ["https://geographyclub.github.io/toronto-map/data/toronto_bia/{z}/{x}/{y}.pbf"]
		},
		"toronto_bia_centroids": {
			"type": "vector",
			"tiles": ["https://geographyclub.github.io/toronto-map/data/toronto_bia_centroids/{z}/{x}/{y}.pbf"]
		},		
		"toronto_buildings": {
			"type": "vector",
			"tiles": ["https://torontotechweek.github.io/data/toronto_buildings/{z}/{x}/{y}.pbf"]
		},
		"toronto_centreline": {
			"type": "vector",
			"tiles": ["https://geographyclub.github.io/toronto-map/data/toronto_centreline/{z}/{x}/{y}.pbf"]
		},
		"toronto_property_boundary_lines": {
			"type": "vector",
			"tiles": ["https://geographyclub.github.io/toronto-map/data/toronto_property_boundary_lines/{z}/{x}/{y}.pbf"]
		},
		"toronto_roadway": {
			"type": "vector",
			"tiles": ["https://mapcity.io/toronto-bia/data/toronto_roadway/{z}/{x}/{y}.pbf"]
		},
		"toronto_address_points": {
			"type": "vector",
			"tiles": ["https://geographyclub.github.io/toronto-map/data/toronto_address_points/{z}/{x}/{y}.pbf"]
		}		
	},
	"layers": [
		{
			"id": "background",
			"type": "background",
			"paint": {
				"background-color": "hsl(50, 10%, 93%)"
			}
		},
		{
			"id": "toronto_ortho",
			"type": "raster",
			"source": "toronto_ortho",
			"paint": {
				"raster-saturation": 0.4,
				"raster-contrast": -0.2,
				"raster-brightness-min": 0,
				"raster-brightness-max": 0.8,
				"raster-hue-rotate": 0,
				"raster-opacity": ["interpolate", ["linear"], ["zoom"], 15, 1, 16, 0]
			}
		},
		{
			"id": "property_boundary_line",
			"source": "toronto_property_boundary_lines",
			"source-layer": "toronto_property_boundary_lines",
			"type": "line",
			"paint": {
				"line-color": "hsl(202, 90%, 100%)",
				"line-width": 2,
				"line-dasharray": [2, 2],
				"line-opacity": ["interpolate", ["linear"], ["zoom"], 15, 0, 16, 1]
			}
		},
		{
			"id": "roadway_outline",
			"source": "toronto_roadway",
			"source-layer": "toronto_roadway",
            "type": "line",
			"paint": {
			  "line-color": "hsl(202, 90%, 16%)",
			  "line-width": 3,
			  "line-opacity": ["interpolate", ["linear"], ["zoom"], 16, 0, 17, 0.4]
			}
		},
		{
			"id": "roadway",
			"source": "toronto_roadway",
			"source-layer": "toronto_roadway",
            "type": "fill",
			"paint": {
			  "fill-color": "hsl(210, 20%, 100%)",
			  "fill-opacity": ["interpolate", ["linear"], ["zoom"], 15, 0, 16, 1]
			}
		},	
		{
			"id": "buildings",
			"source": "toronto_buildings",
			"source-layer": "toronto_buildings",
			"type": "fill-extrusion",
			"paint": {
				"fill-extrusion-color": "hsl(50, 10%, 93%)",
				"fill-extrusion-height": [
					"case",
					["!=", ["get", "max_height"], null], ["get", "max_height"],
					["!=", ["get", "avg_height"], null], ["get", "avg_height"],
					10
				],
				"fill-extrusion-base": 0,
				"fill-extrusion-opacity": ["interpolate", ["linear"], ["zoom"], 15, 0, 16, 0.4, 17, 0.4, 18, 0]
			}
		},
		{
			"id": "neighborhood-labels",
			"type": "symbol",
			"source": "toronto_neighborhood_centroids",
			"source-layer": "toronto_neighborhood_centroids",
			"layout": {
				"text-field": ["get", "area_name"],
				"text-size": [
					"interpolate",
					["linear"],
					["zoom"],
					12, 6,
					16, 40
				],
				"text-font": ["notosans"],
				"text-max-width": 5,
				"text-line-height": 1.2,
				"text-allow-overlap": true,
				"text-ignore-placement": false,
				"text-rotation-alignment": "map",
				"text-pitch-alignment": "map",
				"text-rotate": -16
			},
			"paint": {
				"text-color": "hsl(202, 90%, 100%)",
				"text-opacity": ["interpolate", ["linear"], ["zoom"], 12, 0, 13, 0.8, 15, 0.8, 16, 0],
				"text-halo-width": 0,
				"text-halo-color": "hsl(50, 10%, 93%)"
			}
		},
		{
			"id": "ward-labels",
			"type": "symbol",
			"source": "toronto_ward_centroids",
			"source-layer": "toronto_ward_centroids",
			"layout": {
				"text-field": ["get", "area_name"],
				"text-size": [
					"interpolate",
					["linear"],
					["zoom"],
					10, 4,
					13, 40
				],
				"text-font": ["notosans"],
				"text-max-width": 5,
				"text-line-height": 1.2,
				"text-allow-overlap": true,
				"text-ignore-placement": false,
				"text-rotation-alignment": "map",
				"text-pitch-alignment": "map",
				"text-rotate": -16
			},
			"paint": {
				"text-color": "hsl(202, 90%, 100%)",
				"text-opacity": ["interpolate", ["linear"], ["zoom"], 12, 0.8, 13, 0],
				"text-halo-width": 0,
				"text-halo-color": "hsl(50, 10%, 93%)"
			}
		},
		{
			"id": "centreline_label",
			"source": "toronto_centreline",
			"source-layer": "toronto_centreline",
			"filter": [
				"all",
				["has", "LINEAR_NAME_FULL"],
				[
					"!in",
					"FEATURE_CODE_DESC",
					"Geostatistical line",
					"Other"
				]
			],
			"type": "symbol",
			"layout": {
				"text-field": "{LINEAR_NAME_FULL}",
				"text-transform": "uppercase",
				"text-rotation-alignment": "map",
				"text-font": [ "montserrat-regular" ],
				"text-letter-spacing": 0.2,
				"symbol-placement": "line",
				"symbol-spacing": [ "interpolate", [ "linear" ], [ "zoom" ], 15, 250, 18, 300 ],
				"text-anchor": "center",
				"text-size": [ "interpolate", [ "exponential", 1.5 ], [ "zoom" ], 15, 6, 20, 60 ]
			},
			"paint": {
				"text-color": "hsl(202, 90%, 16%)",
				"text-opacity": [ "interpolate", [ "linear" ], [ "zoom" ], 15, 0, 16, 1 ],
				"text-halo-color": "hsl(50, 10%, 93%)",
				"text-halo-width": 0
			}
		},
		{
			"source": "osm",
			"id": "poi-amenity",
			"type": "symbol",
			"source-layer": "pois",
			"filter": ["all", ["to-boolean", ["get", "amenity"]], ["!=", ["get", "name"], null]],
			"layout": {
				"icon-size": 0.6,
				"symbol-placement": "point",
				"icon-optional": true,
				"icon-image": ["match", ["get", "amenity"], "arts_centre", "icon-art_gallery", "atm", "icon-atm", "bank", "icon-bank", "bar", "icon-bar", "bench", "icon-bench", "bicycle_rental", "icon-bicycle_share", "biergarten", "icon-beergarden", "cafe", "icon-cafe", "car_rental", "icon-car_rental", "car_sharing", "icon-car_rental", "car_wash", "icon-car_wash", "cinema", "icon-cinema", "college", "icon-college", "community_centre", "icon-community", "dentist", "icon-dentist", "doctors", "icon-doctor", "dog_park", "icon-dog_park", "drinking_water", "icon-drinking_water", "embassy", "icon-embassy", "fast_food", "icon-fast_food", "fire_station", "icon-fire_station", "fountain", "icon-fountain", "grave_yard", "icon-cemetery", "hospital", "icon-hospital", "hunting_stand", "icon-huntingstand", "library", "icon-library", "marketplace", "icon-marketplace", "nightclub", "icon-nightclub", "nursing_home", "icon-nursinghome", "pharmacy", "icon-pharmacy", "place_of_worship", "icon-place_of_worship", "playground", "icon-playground", "police", "icon-police", "post_box", "icon-postbox", "post_office", "icon-post", "prison", "icon-prison", "pub", "icon-beer", "recycling", "icon-recycling", "restaurant", "icon-restaurant", "school", "icon-school", "shelter", "icon-shelter", "telephone", "icon-telephone", "theatre", "icon-theatre", "toilets", "icon-toilet", "townhall", "icon-town_hall", "vending_machine", "icon-vendingmachine", "veterinary", "icon-veterinary", "waste_basket", "icon-waste_basket", "transport-information"],
				"text-font": ["montserrat-semibold"],
				"text-size": 6,
				"text-field": ["get", "name"],
				"text-max-width": 8,
				"text-line-height": 1,
				"icon-anchor": "bottom",
				"text-anchor": "top",
				"icon-allow-overlap": false,
				"text-allow-overlap": false,
				"icon-ignore-placement": false,
				"text-ignore-placement": false
			},
			"paint": {
				"icon-opacity": ["interpolate", ["linear"], ["zoom"], 15, 0, 16, 0.8],
				"text-opacity": ["interpolate", ["linear"], ["zoom"], 15, 0, 16, 0.8],
				"icon-color": ["case", ["==", ["get", "amenity"], "bicycle_rental"], "#ffffff", "#ffffff"],
				"text-color": ["case", ["==", ["get", "amenity"], "bicycle_rental"], "#ffffff", "#ffffff"],
				"text-halo-color": "#EEEDEA",
				"text-halo-width": 0,
				"text-halo-blur": 0
			},
			"minzoom": 15
		}		
	]
}
